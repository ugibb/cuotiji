.mine-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

.scroll {
  flex: 1;
}

/* ── 用户 Hero ── */
.user-hero {
  background: linear-gradient(135deg, #5B5FC7 0%, #4338CA 100%);
  padding: 24rpx 32rpx 40rpx;
  color: #fff;
}

.hero-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text text {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 6rpx;
}

.user-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 3 统计 */
.stats-row {
  display: flex;
  gap: 20rpx;
}

.stat-block {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}

.stat-val {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ── 内容区 ── */
.content {
  padding: 24rpx 32rpx 0;
}

/* ── 通用卡片 ── */
.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
}

/* ── 当前项目卡 ── */
.project-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.project-status {
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5FC7;
}

.project-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.project-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}

.progress-track {
  height: 8rpx;
  background: #F3F4F6;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #5B5FC7;
  border-radius: 4rpx;
}

/* ── 家长通知 ── */
.notify-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.notify-border {
  border-bottom: 1rpx solid #F0F1F5;
}

.notify-label {
  font-size: 26rpx;
  color: #111827;
}

.notify-link {
  font-size: 26rpx;
  color: #5B5FC7;
}

/* ── 退出 ── */
.logout-wrap {
  margin-bottom: 20rpx;
}

.btn-logout {
  width: 100%;
  height: 90rpx;
  border-radius: 50rpx;
  background: #fff;
  color: #DC2626;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid rgba(220, 38, 38, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-logout::after { border: none; }

/* ── 版本号 ── */
.version {
  text-align: center;
  padding: 20rpx 0;
}

.version-text {
  font-size: 22rpx;
  color: #D1D5DB;
}
