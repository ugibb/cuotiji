.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

/* 固定头部 */
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

/* NavBar */
.nav-bar {
  background: #fff;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F1F5;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #5B5FC7;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

/* 步骤条 */
.flow-bar {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 32rpx 0;
  background: #fff;
  flex-shrink: 0;
}
.flow-seg {
  flex: 1;
  height: 8rpx;
  border-radius: 4rpx;
  background: #E5E7EB;
}
.seg-now { background: #A5B4FC; }
.seg-done { background: #5B5FC7; }

.step-label {
  display: block;
  background: #fff;
  padding: 8rpx 32rpx 20rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

/* 滚动区 */
.scroll {
  flex: 1;
  padding-top: 24rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
}
.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}
.card-hint {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}

/* 竞赛日期（picker 内） */
.date-item {
  background: #F5F6FA;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 3rpx solid #5B5FC7;
  position: relative;
}
.date-name {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}
.date-val {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 8rpx;
}
.date-val-empty {
  font-size: 30rpx;
  font-weight: 600;
  color: #9CA3AF;
}
.date-days {
  display: block;
  font-size: 22rpx;
  color: #5B5FC7;
  font-weight: 600;
}
.date-tap-hint {
  position: absolute;
  right: 28rpx;
  top: 50%;
  margin-top: -18rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 年级 2 列网格 */
.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
/* choice-half：专用类，避免复合选择器在小程序里不稳定 */
.choice-half {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  margin-bottom: 0;
}

/* 选项通用 */
.choice {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #F5F6FA;
  border: 3rpx solid transparent;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.choice:last-child { margin-bottom: 0; }
.choice-sel {
  background: #EEF0FF;
  border-color: #5B5FC7;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.radio-sel {
  background: #5B5FC7;
  border-color: #5B5FC7;
}
.radio-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}

.choice-text {
  display: block;
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
}
.choice-sel .choice-text {
  color: #4338CA;
  font-weight: 700;
}
.choice-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* 问卷区分隔标题 */
.section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  padding: 8rpx 32rpx 4rpx;
}

/* Q 标题 */
.q-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
}

/* AI 提示条 */
.ai-hint {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  background: #EEF0FF;
  border-radius: 24rpx;
  margin: 0 32rpx 24rpx;
  padding: 24rpx 28rpx;
}
.ai-hint-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.ai-hint-text {
  font-size: 24rpx;
  color: #4338CA;
  line-height: 1.7;
}

/* 底部固定按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F1F5;
}
.btn-primary {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-sizing: border-box;
  white-space: nowrap;
  line-height: 1;
}
.btn-primary::after { border: none; }
.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: inherit;
}
.btn-text-sub {
  font-size: 22rpx;
  font-weight: 500;
  color: inherit;
  opacity: 0.9;
}
.btn-disabled {
  background: #E5E7EB;
  color: #9CA3AF;
}
