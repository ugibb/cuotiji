<view class="page">

  <!-- 固定头部 -->
  <view class="page-header">
    <view style="height:{{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <view class="nav-back" bindtap="onBack">‹</view>
      <text class="nav-title">设置备赛目标</text>
      <view style="width:72rpx"></view>
    </view>
    <view class="flow-bar">
      <view class="flow-seg seg-now"></view>
      <view class="flow-seg"></view>
      <view class="flow-seg"></view>
      <view class="flow-seg"></view>
    </view>
    <text class="step-label">第 1/4 步 · 填写基本信息</text>
  </view>
  <!-- 头部等高占位 -->
  <view style="height:{{headerHeight}}px"></view>

  <scroll-view class="scroll" scroll-y>

    <!-- AI 初步问卷（原 intake 页，合并至此） -->
    <view class="ai-hint">
      <text class="ai-hint-text">🤖 先聊几个问题，让 AI 快速了解你 👋。</text>
    </view>

    <!-- 年级（两列，1-6年级） -->
    <view class="card">
      <text class="card-title">1、孩子目前就读年级</text>
      <view class="grade-grid">
        <view class="choice choice-half {{grade === 'g1' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g1">
          <view class="radio {{grade === 'g1' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g1'}}" class="radio-dot"></view></view>
          <text class="choice-text">一年级</text>
        </view>
        <view class="choice choice-half {{grade === 'g2' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g2">
          <view class="radio {{grade === 'g2' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g2'}}" class="radio-dot"></view></view>
          <text class="choice-text">二年级</text>
        </view>
        <view class="choice choice-half {{grade === 'g3' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g3">
          <view class="radio {{grade === 'g3' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g3'}}" class="radio-dot"></view></view>
          <text class="choice-text">三年级</text>
        </view>
        <view class="choice choice-half {{grade === 'g4' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g4">
          <view class="radio {{grade === 'g4' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g4'}}" class="radio-dot"></view></view>
          <text class="choice-text">四年级</text>
        </view>
        <view class="choice choice-half {{grade === 'g5' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g5">
          <view class="radio {{grade === 'g5' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g5'}}" class="radio-dot"></view></view>
          <text class="choice-text">五年级</text>
        </view>
        <view class="choice choice-half {{grade === 'g6' ? 'choice-sel' : ''}}" bindtap="onGrade" data-val="g6">
          <view class="radio {{grade === 'g6' ? 'radio-sel' : ''}}"><view wx:if="{{grade === 'g6'}}" class="radio-dot"></view></view>
          <text class="choice-text">六年级</text>
        </view>
      </view>
    </view>


    <view class="card">
      <text class="q-title">2、之前学过多久奥数？</text>
      <view class="choice {{q1 === 'none' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q1" data-val="none">
        <view class="radio {{q1 === 'none' ? 'radio-sel' : ''}}"><view wx:if="{{q1 === 'none'}}" class="radio-dot"></view></view>
        <text class="choice-text">从来没学过</text>
      </view>
      <view class="choice {{q1 === 'lt1' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q1" data-val="lt1">
        <view class="radio {{q1 === 'lt1' ? 'radio-sel' : ''}}"><view wx:if="{{q1 === 'lt1'}}" class="radio-dot"></view></view>
        <text class="choice-text">学了不到 1 年</text>
      </view>
      <view class="choice {{q1 === '1to2' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q1" data-val="1to2">
        <view class="radio {{q1 === '1to2' ? 'radio-sel' : ''}}"><view wx:if="{{q1 === '1to2'}}" class="radio-dot"></view></view>
        <text class="choice-text">学了 1-2 年</text>
      </view>
      <view class="choice {{q1 === 'gt2' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q1" data-val="gt2">
        <view class="radio {{q1 === 'gt2' ? 'radio-sel' : ''}}"><view wx:if="{{q1 === 'gt2'}}" class="radio-dot"></view></view>
        <text class="choice-text">2 年以上</text>
      </view>
    </view>

    <view class="card">
      <text class="q-title">3、每天能投入多少时间？</text>
      <view class="choice {{q3 === 'lt30min' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q3" data-val="lt30min">
        <view class="radio {{q3 === 'lt30min' ? 'radio-sel' : ''}}"><view wx:if="{{q3 === 'lt30min'}}" class="radio-dot"></view></view>
        <text class="choice-text">30 分钟以内</text>
      </view>
      <view class="choice {{q3 === '30to60min' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q3" data-val="30to60min">
        <view class="radio {{q3 === '30to60min' ? 'radio-sel' : ''}}"><view wx:if="{{q3 === '30to60min'}}" class="radio-dot"></view></view>
        <text class="choice-text">30-60 分钟</text>
      </view>
      <view class="choice {{q3 === '1to2h' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q3" data-val="1to2h">
        <view class="radio {{q3 === '1to2h' ? 'radio-sel' : ''}}"><view wx:if="{{q3 === '1to2h'}}" class="radio-dot"></view></view>
        <text class="choice-text">1-2 小时</text>
      </view>
      <view class="choice {{q3 === 'gt2h' ? 'choice-sel' : ''}}" bindtap="onPick" data-q="q3" data-val="gt2h">
        <view class="radio {{q3 === 'gt2h' ? 'radio-sel' : ''}}"><view wx:if="{{q3 === 'gt2h'}}" class="radio-dot"></view></view>
        <text class="choice-text">2 小时以上</text>
      </view>
    </view>



    <!-- 竞赛日期 -->
    <view class="card">
      <text class="card-title">4、选择竞赛日期</text>
      <picker mode="date" value="{{examDate}}" start="2025-01-01" end="2030-12-31" bindchange="onDateChange">
        <view class="date-item">
          <text class="date-name">华杯小学数学邀请赛</text>
          <text class="date-val {{examDate ? '' : 'date-val-empty'}}">{{examDateDisplay}}</text>
          <text wx:if="{{examDate}}" class="date-days">● 距今 {{daysLeft}} 天</text>
          <text class="date-tap-hint">选择竞赛日期 ›</text>
        </view>
      </picker>
      <text class="card-hint">如日期有变化，可随时修改</text>
    </view>

    <!-- 参赛目标：三年级以下自动设为「初次参赛」，不显示 -->
    <view class="card" wx:if="{{grade !== 'g1' && grade !== 'g2'}}">
      <text class="card-title">5、本次参赛目标</text>
      <view class="choice {{goal === 'top' ? 'choice-sel' : ''}}" bindtap="onGoal" data-val="top">
        <view class="radio {{goal === 'top' ? 'radio-sel' : ''}}"><view wx:if="{{goal === 'top'}}" class="radio-dot"></view></view>
        <view>
          <text class="choice-text">挑战一等奖 🏆</text>
          <text class="choice-sub">全力冲顶，需要高强度</text>
        </view>
      </view>
      <view class="choice {{goal === 'award' ? 'choice-sel' : ''}}" bindtap="onGoal" data-val="award">
        <view class="radio {{goal === 'award' ? 'radio-sel' : ''}}"><view wx:if="{{goal === 'award'}}" class="radio-dot"></view></view>
        <view>
          <text class="choice-text">冲刺获奖 🏅</text>
          <text class="choice-sub">二等奖及以上（推荐）</text>
        </view>
      </view>
      <view class="choice {{goal === 'entry' ? 'choice-sel' : ''}}" bindtap="onGoal" data-val="entry">
        <view class="radio {{goal === 'entry' ? 'radio-sel' : ''}}"><view wx:if="{{goal === 'entry'}}" class="radio-dot"></view></view>
        <view>
          <text class="choice-text">初次参赛</text>
          <text class="choice-sub">完赛即目标，积累经验</text>
        </view>
      </view>
    </view>


    <!-- AI 提示 -->
    <view class="ai-hint">
      <text class="ai-hint-icon">🤖</text>
      <text class="ai-hint-text">根据你的回答，AI 对孩子已经有了初步了解，接下来是一段更精准的诊断测试，放心作答即可。</text>
    </view>

    <view style="height:200rpx"></view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn-primary {{canNext ? '' : 'btn-disabled'}}" bindtap="onNext">
      <text class="btn-text">开始诊断（约 15 分钟）</text>
      <text class="btn-text">→</text>
    </button>
  </view>

</view>
