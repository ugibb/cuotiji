<view class="page">

  <!-- 状态栏占位 -->
  <view style="height:{{statusBarHeight}}px;background:#fff"></view>

  <!-- 顶部 -->
  <view class="top-bar">
    <view class="top-bar-inner">
      <text class="app-tag">AI 错题集 · 项目制学习</text>
    </view>
  </view>

  <!-- Hero 渐变头部 -->
  <view class="hero">
    <view class="hero-deco">华</view>
    <view class="hero-content">
      <text class="hero-greeting">你好，小朋友 👋</text>
      <text class="hero-sub">华杯赛还有 <text class="hero-days">{{daysLeft}}</text> 天\nAI 已为你准备好专属备赛计划</text>
    </view>
    <view class="hero-stats">
      <view class="stat-pill">
        <text class="stat-val">免费</text>
        <text class="stat-label">14天体验</text>
      </view>
      <view class="stat-pill">
        <text class="stat-val">≈25min</text>
        <text class="stat-label">完成诊断</text>
      </view>
      <view class="stat-pill">
        <text class="stat-val">每日</text>
        <text class="stat-label">微信日报</text>
      </view>
    </view>
  </view>

  <!-- 价值主张列表 -->
  <scroll-view class="scroll" scroll-y>
    <view class="card">
      <text class="card-title">培训班有 4 个结构性缺陷，我们逐一解决</text>
      <view class="value-list">
        <view class="value-item">
          <text class="value-icon">🎯</text>
          <view>
            <text class="value-heading">AI 诊断 → 精确到每个知识点薄弱程度</text>
            <text class="value-sub">不是"进快班慢班"，是你专属的能力报告</text>
          </view>
        </view>
        <view class="value-item">
          <text class="value-icon">📅</text>
          <view>
            <text class="value-heading">每日任务 + 遗忘曲线复习，全程追踪</text>
            <text class="value-sub">下课了事 → 每天执行记录可见</text>
          </view>
        </view>
        <view class="value-item">
          <text class="value-icon">📲</text>
          <view>
            <text class="value-heading">每日微信日报，家长全程可见</text>
            <text class="value-sub">过程黑箱 → 实时透明</text>
          </view>
        </view>
        <view class="value-item">
          <text class="value-icon">💰</text>
          <view>
            <text class="value-heading">全年 499 元 = 培训班一节课</text>
            <text class="value-sub">一年费用 vs 培训班单次费用</text>
          </view>
        </view>
      </view>
    </view>

    <view class="cta-wrap">
      <button class="btn-primary" bindtap="onStart">开始备赛，免费诊断能力 →</button>
      <text class="cta-hint">14天免费体验 · 完成能力报告后开始计时</text>
    </view>

    <view style="height:40rpx"></view>
  </scroll-view>

</view>
