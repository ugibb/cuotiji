.page { display: flex; flex-direction: column; min-height: 100vh; background: #F5F6FA; }
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.nav-bar {
  background: #fff;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F1F5;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #5B5FC7;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}
.flow-bar { display: flex; gap: 8rpx; padding: 20rpx 32rpx 0; background: #fff; flex-shrink: 0; }
.flow-seg { flex: 1; height: 8rpx; border-radius: 4rpx; background: #E5E7EB; }
.seg-done { background: #5B5FC7; }
.seg-now { background: #A5B4FC; }
.step-label { display: block; background: #fff; padding: 8rpx 32rpx 16rpx; font-size: 22rpx; color: #9CA3AF; flex-shrink: 0; }

.scroll { flex: 1; padding: 16rpx 0 0; }

.card { background: #fff; border-radius: 32rpx; padding: 28rpx 32rpx; margin: 0 32rpx 24rpx; }

/* 总览 */
.overview-card {}
.overview-stats {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0 24rpx;
  border-bottom: 2rpx solid #F0F1F5;
  margin-bottom: 24rpx;
}
.stat-col { text-align: center; }
.stat-num { display: block; font-size: 48rpx; font-weight: 900; color: #111827; }
.stat-label { display: block; font-size: 22rpx; color: #9CA3AF; }
.stat-label-row { display: flex; align-items: center; justify-content: center; gap: 6rpx; }
.edit-hint { font-size: 20rpx; color: #5B5FC7; }
.stat-divider { width: 2rpx; background: #F0F1F5; }

/* 可编辑列 */
.editable { position: relative; }
.picker-fill { width: 100%; display: flex; flex-direction: column; align-items: center; }
.goal-row { display: flex; align-items: center; gap: 12rpx; }
.goal-icon { font-size: 28rpx; }
.goal-text { font-size: 24rpx; color: #6B7280; }

/* 里程碑包裹层：重算时半透明 */
.milestones-wrap { transition: opacity 0.2s; }
.milestones-wrap.recalculating { opacity: 0.4; }
.recalc-tip {
  text-align: center;
  padding: 12rpx 0;
  margin: 0 32rpx 8rpx;
}
.recalc-text { font-size: 22rpx; color: #5B5FC7; }

/* 里程碑卡 */
.ms-card {
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
  background: #fff;
  position: relative;
  overflow: hidden;
}
.ms-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  border-radius: 8rpx 0 0 8rpx;
}
.ms-m1::before { background: #5B5FC7; }
.ms-m2::before { background: #F59E0B; }
.ms-m3::before { background: #10B981; }
.ms-blue::before  { background: #5B5FC7; }
.ms-amber::before { background: #F59E0B; }
.ms-green::before { background: #10B981; }

.ms-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.ms-left { display: flex; align-items: center; gap: 16rpx; }
.ms-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
}
.ms-tag-blue { background: #EEF0FF; color: #5B5FC7; }
.ms-tag-amber { background: #FFFBEB; color: #D97706; }
.ms-tag-green { background: #ECFDF5; color: #059669; }
.ms-title { font-size: 28rpx; font-weight: 700; color: #111827; }
.ms-days { font-size: 22rpx; color: #9CA3AF; }
.ms-date { display: block; font-size: 22rpx; color: #9CA3AF; margin-bottom: 16rpx; }

.ms-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 16rpx; }
.chip {
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.chip-blue { background: #EEF0FF; color: #5B5FC7; }
.chip-amber { background: #FFFBEB; color: #D97706; }
.chip-green { background: #EDFCF2; color: #16A34A; }

.ms-goal { display: block; font-size: 24rpx; font-weight: 600; }
.ms-goal-blue { color: #5B5FC7; }
.ms-goal-amber { color: #D97706; }
.ms-goal-green { color: #059669; }

/* 提示卡 */
.hint-card {
  background: #EEF0FF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin: 0 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.hint-line { display: block; font-size: 24rpx; color: #4338CA; line-height: 1.7; }

/* 底部 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F1F5;
}
.btn-primary {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff; font-size: 32rpx; font-weight: 700; border: none;
  display: flex; align-items: center; justify-content: center;
}
.btn-primary::after { border: none; }
.btn-disabled { background: #E5E7EB !important; color: #9CA3AF !important; }
