.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F6FA;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.nav-bar {
  background: #fff;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F1F5;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #5B5FC7;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.msg-list {
  flex: 1;
  padding: 24rpx 32rpx;
}

.ai-bubble {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.ai-msg {
  max-width: 480rpx;
  background: #fff;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.7;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 28rpx;
}

.user-msg {
  max-width: 440rpx;
  background: #5B5FC7;
  border-radius: 32rpx 8rpx 32rpx 32rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.7;
}
