.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.nav-bar {
  background: #fff;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F1F5;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #5B5FC7;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}
.nav-count {
  font-size: 24rpx;
  color: #9CA3AF;
  flex-shrink: 0;
  width: 72rpx;
  text-align: right;
}
.flow-bar {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 32rpx 0;
  background: #fff;
  flex-shrink: 0;
}
.flow-seg {
  flex: 1;
  height: 8rpx;
  border-radius: 4rpx;
  background: #E5E7EB;
}
.seg-done { background: #5B5FC7; }
.seg-now { background: #A5B4FC; }
.step-label {
  display: block;
  background: #fff;
  padding: 8rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.scroll { flex: 1; padding: 16rpx 0 0; }

.intro {
  display: block;
  padding: 0 32rpx 16rpx;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.topic-chip {
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.topic-blue   { background: #EEF0FF; color: #5B5FC7; }
.topic-amber  { background: #FFFBEB; color: #D97706; }
.topic-green  { background: #EDFCF2; color: #16A34A; }
.topic-purple { background: #F5F3FF; color: #7C3AED; }
.topic-teal   { background: #F0FDFA; color: #0F766E; }
.topic-rose   { background: #FFF1F2; color: #E11D48; }
.q-num { font-size: 22rpx; color: #9CA3AF; }

.q-body {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.q-text {
  font-size: 28rpx;
  color: #111827;
  line-height: 1.9;
  font-family: Georgia, serif;
}

.choices {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.choice {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #F5F6FA;
  border: 3rpx solid transparent;
}
.choice-sel {
  background: #EEF0FF;
  border-color: #5B5FC7;
}
.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.radio-sel { background: #5B5FC7; border-color: #5B5FC7; }
.radio-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #fff; }
.choice-text { font-size: 26rpx; color: #374151; }
.choice-sel .choice-text { color: #4338CA; font-weight: 600; }


.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F1F5;
}
.answer-progress {
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6B7280;
}
.btn-primary {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }
.btn-disabled { background: #E5E7EB !important; color: #9CA3AF !important; }
