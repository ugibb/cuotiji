.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.nav-bar {
  background: #fff;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F0F1F5;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #5B5FC7;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}
.flow-bar { display: flex; gap: 8rpx; padding: 20rpx 32rpx 0; background: #fff; flex-shrink: 0; }
.flow-seg { flex: 1; height: 8rpx; border-radius: 4rpx; background: #E5E7EB; }
.seg-done { background: #5B5FC7; }
.seg-now { background: #A5B4FC; }
.step-label { display: block; background: #fff; padding: 8rpx 32rpx 16rpx; font-size: 22rpx; color: #9CA3AF; flex-shrink: 0; }

.scroll { flex: 1; padding: 16rpx 0 0; }

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
}
.card-title { display: block; font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 8rpx; }
.card-sub { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 24rpx; }

/* 定级 */
.level-row { display: flex; align-items: center; gap: 24rpx; }
.level-badge {
  width: 96rpx; height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.level-char { font-size: 40rpx; font-weight: 900; color: #fff; }
.level-info { flex: 1; }
.level-name { display: block; font-size: 32rpx; font-weight: 800; color: #111827; }
.level-desc { display: block; font-size: 24rpx; color: #6B7280; margin-top: 4rpx; }
.score-box { text-align: right; }
.score-val { display: block; font-size: 44rpx; font-weight: 900; color: #5B5FC7; line-height: 1; }
.score-label { display: block; font-size: 20rpx; color: #9CA3AF; }

/* 雷达图 */
.radar-wrap { display: flex; justify-content: center; padding: 16rpx 0 24rpx; }
.radar-canvas { width: 600rpx; height: 600rpx; }

/* 薄弱点列表 */
.domain-list { display: flex; flex-direction: column; gap: 12rpx; }
.domain-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
}
.domain-weak { background: #FEF2F2; }
.domain-medium { background: #FFFBEB; }
.domain-strong { background: #EDFCF2; }
.domain-name { display: block; font-size: 24rpx; font-weight: 700; }
.domain-weak .domain-name { color: #DC2626; }
.domain-medium .domain-name { color: #D97706; }
.domain-strong .domain-name { color: #16A34A; }
.domain-sub { display: block; font-size: 22rpx; color: #9CA3AF; margin-top: 4rpx; }
.domain-score { font-size: 36rpx; font-weight: 900; }
.domain-weak .domain-score { color: #DC2626; }
.domain-medium .domain-score { color: #D97706; }
.domain-strong .domain-score { color: #16A34A; }
.domain-unit { font-size: 22rpx; font-weight: 500; }

/* AI 校正对话预览卡片 */
.chat-preview-card { padding: 24rpx 28rpx; }

.mini-avatar {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 18rpx; font-weight: 700; flex-shrink: 0;
}

.mini-ai-bubble {
  display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 16rpx;
}
.mini-ai-msg {
  flex: 1;
  background: #F5F6FA;
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx; color: #111827; line-height: 1.6;
}

.mini-user-bubble {
  display: flex; justify-content: flex-end; margin-bottom: 16rpx;
}
.mini-user-msg {
  max-width: 380rpx;
  background: #5B5FC7;
  border-radius: 24rpx 6rpx 24rpx 24rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx; color: #fff; line-height: 1.6;
}

/* 仿输入框引导条 */
.mini-reply-bar {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 4rpx;
  height: 72rpx;
  background: #F5F6FA;
  border-radius: 36rpx;
  padding: 0 24rpx;
}
.mini-reply-hint { font-size: 28rpx; color: #B8BCC8; }

/* 麦克风图标（复用 chat-input 图标结构，页面作用域） */
.ic-mic {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.mic-body {
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 13rpx;
  height: 19rpx;
  background: #9CA3AF;
  border-radius: 7rpx;
}
.mic-arc {
  position: absolute;
  bottom: 7rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 22rpx;
  height: 10rpx;
  border: 3rpx solid #9CA3AF;
  border-top: none;
  border-radius: 0 0 11rpx 11rpx;
  box-sizing: border-box;
}
.mic-stem {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 3rpx;
  height: 7rpx;
  background: #9CA3AF;
  border-radius: 2rpx;
}
/* 底部固定区（确认按钮 + chat-input 组件） */
.bottom-fixed {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx env(safe-area-inset-bottom);
  border-top: 1rpx solid #F0F1F5;
  z-index: 200;
}
.btn-primary {
  width: 100% !important;
  height: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff; border: none;
  display: flex; align-items: center; justify-content: center;
}
.btn-primary::after { border: none; }
