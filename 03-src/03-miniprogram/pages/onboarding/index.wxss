.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

.top-bar {
  background: #fff;
}
.top-bar-inner {
  padding: 8rpx 40rpx 16rpx;
}
.app-tag {
  font-size: 22rpx;
  color: #9CA3AF;
  letter-spacing: 2rpx;
}

/* Hero */
.hero {
  background: linear-gradient(150deg, #4338CA 0%, #5B5FC7 50%, #818CF8 100%);
  padding: 56rpx 40rpx 64rpx;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.hero-deco {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  font-size: 260rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.05);
  line-height: 1;
  pointer-events: none;
}
.hero-content {
  position: relative;
}
.hero-greeting {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 12rpx;
}
.hero-sub {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.6;
  margin-bottom: 36rpx;
}
.hero-days {
  color: #FCD34D;
  font-size: 32rpx;
  font-weight: 800;
}
.hero-stats {
  display: flex;
  gap: 20rpx;
  position: relative;
}
.stat-pill {
  flex: 1;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 20rpx;
  text-align: center;
}
.stat-val {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

/* Content */
.scroll {
  flex: 1;
  padding: 32rpx 0 16rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
}
.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}
.value-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.value-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}
.value-icon {
  font-size: 28rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
}
.value-heading {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}
.value-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.cta-wrap {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-primary {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }
.cta-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
}
