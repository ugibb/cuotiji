<view class="home-page">

  <!-- 顶部安全区占位（覆盖 statusBar + 胶囊按钮 navBar，避免重叠） -->
  <view style="height:{{navAreaHeight}}px;background:{{hasPlan ? '#4338CA' : '#5B5FC7'}}"></view>

  <!-- ── 无项目：Landing 状态 ── -->
  <block wx:if="{{!hasPlan && !loading}}">

    <!-- 渐变 Hero -->
    <view class="landing-hero">
      <view class="landing-deco">华</view>
      <view class="landing-content">
        <text class="landing-greeting">你好，小朋友 👋</text>
        <text class="landing-sub">华杯赛还有 <text class="landing-days">{{daysLeft}}</text> 天\nAI 已为你准备好专属备赛计划</text>
      </view>
      <view class="landing-stats">
        <view class="stat-pill"><text class="stat-val">免费</text><text class="stat-label">14天体验</text></view>
        <view class="stat-pill"><text class="stat-val">≈25min</text><text class="stat-label">完成诊断</text></view>
        <view class="stat-pill"><text class="stat-val">每日</text><text class="stat-label">微信日报</text></view>
      </view>
    </view>

    <!-- 价值主张 -->
    <scroll-view class="page-scroll" scroll-y>
      <view class="landing-card">
        <text class="landing-card-title">培训班有 4 个结构性缺陷，我们逐一解决</text>
        <view class="value-list">
          <view class="value-item">
            <text class="v-icon">🎯</text>
            <view>
              <text class="v-head">AI 诊断 → 精确到每个知识点薄弱程度</text>
              <text class="v-sub">不是"进快班慢班"，是你专属的能力报告</text>
            </view>
          </view>
          <view class="value-item">
            <text class="v-icon">📅</text>
            <view>
              <text class="v-head">每日任务 + 遗忘曲线复习，全程追踪</text>
              <text class="v-sub">下课了事 → 每天执行记录可见</text>
            </view>
          </view>
          <view class="value-item">
            <text class="v-icon">📲</text>
            <view>
              <text class="v-head">每日微信日报，家长全程可见</text>
              <text class="v-sub">过程黑箱 → 实时透明</text>
            </view>
          </view>
          <view class="value-item">
            <text class="v-icon">💰</text>
            <view>
              <text class="v-head">全年 499 元 = 培训班一节课</text>
              <text class="v-sub">一年费用 vs 培训班单次费用</text>
            </view>
          </view>
        </view>
      </view>
      <view class="landing-cta-wrap">
        <button class="btn-primary" bindtap="onStartSetup">免费能力诊断 →</button>
        <text class="cta-hint">14天免费体验 · 完成能力报告后开始计时</text>
      </view>
      <view style="height:60rpx"></view>
    </scroll-view>
  </block>

  <!-- ── 有项目：执行态 ── -->
  <block wx:elif="{{hasPlan}}">

    <!-- 每日名言 Hero -->
    <view class="exec-hero">
      <text class="quote-deco">’’</text>
      <view class="hero-inner">
        <text class="hero-date">{{todayDateFull}}</text>
        <text class="hero-quote">{{quote}}</text>
        <text class="hero-quote-from">——{{quoteFrom}}</text>
      </view>
    </view>

    <scroll-view class="page-scroll" scroll-y>

      <!-- 项目燃尽图 -->
      <view class="card burndown-card">
        <view class="bd-stage-row">
          <view class="bd-m1-badge">{{milestoneLabel}}</view>
          <view class="bd-stage-info">
            <view class="bd-stage-meta">
              <text class="bd-stage-label">当前阶段目标</text>
              <text class="bd-stage-sub">{{milestoneDeadline}}</text>
            </view>
            <text class="bd-stage-title">{{weeklyChapter}}</text>
          </view>
        </view>
        <view class="bd-progress-section">
          <view class="bd-seg-tracks">
            <view
              wx:for="{{milestoneSegs}}"
              wx:key="label"
              class="bd-seg-track {{item.isActive ? 'bd-seg-active' : ''}}"
              style="flex:{{item.flex}}"
            >
              <view class="bd-seg-fill" style="width:{{item.fillPct}}%"></view>
              <text class="bd-seg-label">{{item.label}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 训练日历 + 今日任务（合并卡） -->
      <view class="card">

        <!-- 日历头 -->
        <view class="cal-top">
          <text class="card-title">训练日历</text>
          <view class="cal-nav">
            <text bindtap="onPrevWeek" class="nav-btn">‹</text>
            <text class="cal-month">{{calRangeLabel}}</text>
            <text bindtap="onNextWeek" class="nav-btn">›</text>
          </view>
        </view>
        <view class="weekdays">
          <text>一</text><text>二</text><text>三</text>
          <text>四</text><text>五</text><text>六</text><text>日</text>
        </view>
        <view class="calendar-grid">
          <view
            wx:for="{{calendarDays}}"
            wx:key="index"
            class="day-wrap {{item.date === selectedDate ? 'day-selected' : ''}}"
            data-date="{{item.date}}"
            bindtap="onDayTap"
          >
            <view wx:if="{{item.date}}" class="day-circle {{item.circleClass}}">
              <text class="day-num {{item.numClass}}">{{item.day}}</text>
            </view>
            <view wx:if="{{item.date && item.underlineClass}}" class="day-underline {{item.underlineClass}}"></view>
          </view>
        </view>

        <!-- 图例  -->
        <view class="cal-legend">
          <view class="legend-item">
            <view class="legend-dot dot-green"></view>
            <text class="legend-text">已完成</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot dot-orange"></view>
            <text class="legend-text">待登记错题</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot dot-red"></view>
            <text class="legend-text">作业未上传</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot dot-gray"></view>
            <text class="legend-text">待训练</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot dot-dim"></view>
            <text class="legend-text">休息日</text>
          </view>
        </view>
        

        <!-- 选中日详情（含今日） -->
        <view class="day-detail" wx:if="{{selectedDate && selectedDayPlan}}">
          <view class="detail-top">
            <text class="detail-date">{{selectedDayLabel}}</text>
            <view class="chapter-pill">{{selectedDayPlan.chapter.name}}</view>
          </view>
          <text class="detail-topic">{{selectedDayPlan.topic || selectedDayPlan.chapter.name}}</text>
          <view wx:if="{{selectedDayPlan.keyPoints && selectedDayPlan.keyPoints.length}}" class="kp-wrap">
            <text class="kp-title">本日训练要点</text>
            <view wx:for="{{selectedDayPlan.keyPoints}}" wx:key="*this" class="kp-item">
              <text class="kp-bullet">•</text>
              <text class="kp-text">{{item}}</text>
            </view>
          </view>
          <button wx:if="{{selectedDayStatus === 'done'}}" class="btn-action-green" bindtap="onDayActionView">查看打卡记录</button>
          <button wx:elif="{{selectedDayStatus === 'uploaded_pending'}}" class="btn-action-orange" bindtap="onDayActionReview">登记错题</button>
          <button wx:else class="btn-action-red" bindtap="onDayActionUpload">📷 上传作业</button>
        </view>

        <!-- 无训练计划日期说明 -->
        <view class="day-no-plan" wx:if="{{selectedDate && !selectedDayPlan}}">
          <text class="no-plan-emoji">🌿</text>
          <text class="no-plan-title">今日无训练安排</text>
          <text class="no-plan-sub">{{selectedDayLabel}}，休息调整\n保持状态，明天继续加油</text>
        </view>

      </view>

      <!-- 项目进度入口 -->
      <view class="card project-entry" bindtap="onGoProject">
        <view class="project-entry-left">
          <view class="project-icon">📊</view>
          <view>
            <text class="project-entry-title">查看项目进度看板</text>
            <text class="project-entry-sub">M1 进行中 · {{m1Pct}}% · {{m1Day}}/21天</text>
          </view>
        </view>
        <text class="project-arrow">›</text>
      </view>

      <!-- 弱点地图入口 -->
      <view class="card project-entry" bindtap="onGoWeaknessMap">
        <view class="project-entry-left">
          <view class="project-icon weakness-icon">🗺️</view>
          <view>
            <text class="project-entry-title">弱点地图</text>
            <text class="project-entry-sub">查看易错知识点分布与掌握情况</text>
          </view>
        </view>
        <text class="project-arrow">›</text>
      </view>

      <!-- 每日复习入口 -->
      <view class="card project-entry" bindtap="onGoDailyReview">
        <view class="project-entry-left">
          <view class="project-icon review-icon">📖</view>
          <view>
            <text class="project-entry-title">每日复习</text>
            <text class="project-entry-sub">针对错题与弱点的每日巩固练习</text>
          </view>
        </view>
        <text class="project-arrow">›</text>
      </view>

      <!-- 最近完成 -->
      <view class="card" wx:if="{{recentPractices.length > 0}}">
        <text class="card-title">最近完成</text>
        <view class="recent-list">
          <view wx:for="{{recentPractices}}" wx:key="index" class="recent-item">
            <view class="recent-info">
              <text class="recent-topic">{{item.topic}}</text>
              <text class="recent-date">{{item.date}} · {{item.totalCount}}题</text>
            </view>
            <view class="recent-scores">
              <view wx:if="{{item.correctCount > 0}}" class="chip chip-green">{{item.correctCount}}对</view>
              <view wx:if="{{item.wrongCount > 0}}" class="chip chip-red">{{item.wrongCount}}错</view>
            </view>
          </view>
        </view>
      </view>

      <view style="height:60rpx"></view>
    </scroll-view>
  </block>

  <!-- 加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <view class="loading-spinner"></view>
  </view>

</view>
