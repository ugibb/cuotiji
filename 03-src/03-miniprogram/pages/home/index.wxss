.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

/* ── Landing: 顶栏 ── */
.landing-topbar {
  background: #fff;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
}

.landing-appname {
  font-size: 26rpx;
  font-weight: 700;
  color: #5B5FC7;
  letter-spacing: 1rpx;
}

/* ── Landing: Hero 渐变区 ── */
.landing-hero {
  background: linear-gradient(135deg, #5B5FC7 0%, #4338CA 100%);
  padding: 40rpx 36rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.landing-deco {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  font-size: 280rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.06);
  line-height: 1;
  pointer-events: none;
}

.landing-content {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.landing-greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 16rpx;
}

.landing-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
}

.landing-days {
  font-size: 32rpx;
  font-weight: 900;
  color: #FFE08A;
}

.landing-stats {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
}

.stat-pill {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-val {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── 可滚动区 ── */
.page-scroll {
  flex: 1;
  overflow: hidden;
}

/* ── Landing: 价值主张卡片 ── */
.landing-card {
  background: #fff;
  border-radius: 32rpx;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
}

.landing-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 24rpx;
}

.value-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.value-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.v-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.v-head {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 4rpx;
}

.v-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.landing-cta-wrap {
  padding: 24rpx 32rpx 0;
}

.cta-hint {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-top: 16rpx;
}

/* ── Active: 每日名言 Hero ── */
.exec-hero {
  background: linear-gradient(135deg, #5B5FC7 0%, #4338CA 100%);
  padding: 36rpx 36rpx 44rpx;
  position: relative;
  overflow: hidden;
}

.quote-deco {
  position: absolute;
  top: -24rpx;
  right: 20rpx;
  font-size: 200rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.1);
  line-height: 1;
  pointer-events: none;
  font-family: Georgia, serif;
}

.hero-inner {
  position: relative;
  z-index: 1;
}

.hero-date {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.hero-quote {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.35;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
}

.hero-quote-from {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: right;
}

/* ── 项目燃尽图卡（白底 + 靛蓝进度条） ── */
.card.burndown-card {
  /* 继承 .card 白底，仅控制内部布局 */
  overflow: hidden;
}

.bd-stage-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.bd-m1-badge {
  width: 56rpx;
  height: 56rpx;
  background: #4338CA;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.bd-stage-info {
  flex: 1;
}

.bd-stage-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.bd-stage-label {
  font-size: 18rpx;
  color: #9CA3AF;
}

.bd-stage-sub {
  font-size: 18rpx;
  color: #9CA3AF;
}

.bd-stage-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.25;
}

.bd-progress-section {
  position: relative;
  z-index: 1;
}

.bd-seg-tracks {
  display: flex;
  gap: 6rpx;
}

.bd-seg-track {
  position: relative;
  height: 44rpx;
  border-radius: 8rpx;
  background: #818CF8;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bd-seg-fill {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  background: #4338CA;
  border-radius: 8rpx;
}

.bd-seg-label {
  position: relative;
  z-index: 1;
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}

.bd-seg-active .bd-seg-label {
  font-weight: 800;
  color: #fff;
}

/* ── 日历图例 ── */
.cal-legend {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0 8rpx;
  border-top: 1rpx solid #F0F1F5;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-green  { background: #4ADE80; }
.dot-orange { background: #FB923C; }
.dot-red    { background: #F87171; }
.dot-gray   { background: #CBD5E1; }
.dot-dim    { background: #E2E8F0; }

.legend-text {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* ── 今日任务卡 ── */
.today-in-card {
  margin-bottom: 4rpx;
}

.today-cal-divider {
  height: 1rpx;
  background: #F0F1F5;
  margin: 24rpx 0;
}

/* 训练要点列表 */
.kp-wrap {
  margin-bottom: 20rpx;
}

.kp-title {
  display: block;
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 10rpx;
}

.kp-item {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.kp-bullet {
  font-size: 22rpx;
  color: #5B5FC7;
  flex-shrink: 0;
  line-height: 1.4;
}

.kp-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.4;
}

/* ── 通用卡片 ── */
.card {
  background: #fff;
  border-radius: 32rpx;
  margin: 14rpx 28rpx 0;
  padding: 20rpx 26rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
}

/* ── 训练日历 ── */
.cal-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.cal-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cal-month {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.nav-btn {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 0 8rpx;
}

.weekdays {
  display: flex;
  margin-bottom: 12rpx;
}

.weekdays text {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-wrap {
  flex: 0 0 14.2857%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 5rpx 0;
}

.day-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.c-done    { background: #DCFCE7; }
.c-miss    { background: #FEE2E2; }
.c-pending { background: #FFEDD5; }
.c-future  { background: #F3F4F6; }
.c-today   { border: 2rpx solid #5B5FC7; }

.day-selected .day-circle {
  background: #4338CA;
}

.day-selected .day-num {
  color: #fff;
  font-weight: 800;
}

.day-num {
  font-size: 25rpx;
  font-weight: 500;
  color: #374151;
  line-height: 1;
}

.n-done    { color: #16A34A; font-weight: 700; }
.n-miss    { color: #DC2626; font-weight: 700; }
.n-pending { color: #EA580C; font-weight: 700; }
.n-noplan  { color: #C4C9D4; }
.n-today   { font-weight: 900; }

.day-underline {
  width: 58rpx;
  height: 7rpx;
  border-radius: 100rpx;
  margin-top: 4rpx;
}

.ul-green  { background: #4ADE80; }
.ul-red    { background: #F87171; }
.ul-orange { background: #FB923C; }
.ul-gray   { background: #CBD5E1; }
.ul-dim    { background: #E2E8F0; }

/* ── 选中日详情 ── */
.day-detail {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #F0F1F5;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

/* ── 无计划日期详情 ── */
.day-no-plan {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F1F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 8rpx;
  gap: 10rpx;
}

.no-plan-emoji { font-size: 48rpx; }

.no-plan-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #374151;
}

.no-plan-sub {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.6;
}

.detail-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

.chapter-pill {
  background: #EEF0FF;
  color: #5B5FC7;
  border-radius: 100rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.detail-topic {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
}

.done-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #EDFCF2;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.done-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #16A34A;
}

.btn-action-green {
  width: 100% !important;
  height: 88rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #22C55E, #16A34A);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-green::after { border: none; }

.btn-action-orange {
  width: 100% !important;
  height: 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #FB923C, #EA580C);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-orange::after { border: none; }

.btn-action-red {
  width: 100% !important;
  height: 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #F87171, #DC2626);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-red::after { border: none; }

.btn-action-primary {
  width: 100% !important;
  height: 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-primary::after { border: none; }

/* ── 项目进度入口卡 ── */
.project-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.project-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.project-icon {
  width: 80rpx;
  height: 80rpx;
  background: #EEF0FF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.project-entry-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 4rpx;
}

.project-entry-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.project-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

.weakness-icon {
  background: #FFF4EC;
}

.review-icon {
  background: #F0FDF4;
}

/* ── 最近完成 ── */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recent-info {
  flex: 1;
}

.recent-topic {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4rpx;
}

.recent-date {
  display: block;
  font-size: 20rpx;
  color: #9CA3AF;
}

.recent-scores {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.chip {
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.chip-green {
  background: #EDFCF2;
  color: #16A34A;
}

.chip-red {
  background: #FEE2E2;
  color: #DC2626;
}

/* ── 通用主按钮 ── */
.btn-primary {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  text-align: center;
  box-sizing: border-box;
}
.btn-primary::after { border: none; }

.today-btn { font-size: 28rpx; }

/* ── Loading 遮罩 ── */
.loading-mask {
  position: fixed;
  inset: 0;
  background: rgba(245, 246, 250, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #E5E7EB;
  border-top-color: #5B5FC7;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
