.home-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

/* ── Landing: 顶栏 ── */
.landing-topbar {
  background: #fff;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
}

.landing-appname {
  font-size: 26rpx;
  font-weight: 700;
  color: #5B5FC7;
  letter-spacing: 1rpx;
}

/* ── Landing: Hero 渐变区 ── */
.landing-hero {
  background: linear-gradient(135deg, #5B5FC7 0%, #4338CA 100%);
  padding: 40rpx 36rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.landing-deco {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  font-size: 280rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.06);
  line-height: 1;
  pointer-events: none;
}

.landing-content {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.landing-greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 16rpx;
}

.landing-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
}

.landing-days {
  font-size: 32rpx;
  font-weight: 900;
  color: #FFE08A;
}

.landing-stats {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
}

.stat-pill {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-val {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── 可滚动区 ── */
.page-scroll {
  flex: 1;
  overflow: hidden;
}

/* ── Landing: 价值主张卡片 ── */
.landing-card {
  background: #fff;
  border-radius: 32rpx;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
}

.landing-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 24rpx;
}

.value-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.value-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.v-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.v-head {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 4rpx;
}

.v-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.landing-cta-wrap {
  padding: 24rpx 32rpx 0;
}

.cta-hint {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-top: 16rpx;
}

/* ── Active: Hero 倒计时区 ── */
.exec-hero {
  background: linear-gradient(135deg, #5B5FC7 0%, #4338CA 100%);
  padding: 28rpx 36rpx 36rpx;
  position: relative;
  overflow: hidden;
}

.exec-hero-deco {
  position: absolute;
  right: -16rpx;
  top: -20rpx;
  font-size: 280rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.06);
  line-height: 1;
  pointer-events: none;
}

.exec-hero-main {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.countdown-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.countdown-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.countdown-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.countdown-unit {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
}

.exec-hero-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.ms-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.ms-pill {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.ms-day-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* M1 进度条 */
.exec-progress {
  position: relative;
  z-index: 1;
}

.exec-progress-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.exec-progress-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.exec-progress-pct {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.exec-bar-track {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.exec-bar-fill {
  height: 100%;
  background: #fff;
  border-radius: 5rpx;
}

.ms-seg-row {
  display: flex;
  gap: 6rpx;
  margin-bottom: 6rpx;
}

.ms-seg {
  flex: 1;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3rpx;
}

.ms-seg-active {
  background: #fff;
}

.ms-seg-labels {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ── 今日任务卡 ── */
.today-in-card {
  margin-bottom: 4rpx;
}

.today-cal-divider {
  height: 1rpx;
  background: #F0F1F5;
  margin: 24rpx 0;
}

/* 训练要点列表 */
.kp-wrap {
  margin-bottom: 24rpx;
}

.kp-title {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 14rpx;
}

.kp-item {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.kp-bullet {
  font-size: 24rpx;
  color: #5B5FC7;
  flex-shrink: 0;
  line-height: 1.5;
}

.kp-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.5;
}

/* ── 通用卡片 ── */
.card {
  background: #fff;
  border-radius: 32rpx;
  margin: 20rpx 32rpx 0;
  padding: 28rpx 32rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
}

/* ── 训练日历 ── */
.cal-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.cal-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cal-month {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.nav-btn {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 0 8rpx;
}

.weekdays {
  display: flex;
  margin-bottom: 12rpx;
}

.weekdays text {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-wrap {
  flex: 0 0 14.2857%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.day-circle {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.c-done    { background: #DCFCE7; }
.c-miss    { background: #FEE2E2; }
.c-pending { background: #FFEDD5; }
.c-future  { background: #F3F4F6; }
.c-today   { border: 2rpx solid #5B5FC7; }

.day-selected .day-circle {
  background: #4338CA;
}

.day-selected .day-num {
  color: #fff;
  font-weight: 800;
}

.day-num {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  line-height: 1;
}

.n-done    { color: #16A34A; font-weight: 700; }
.n-miss    { color: #DC2626; font-weight: 700; }
.n-pending { color: #EA580C; font-weight: 700; }
.n-noplan  { color: #C4C9D4; }
.n-today   { font-weight: 900; }

.day-underline {
  width: 45rpx;
  height: 8rpx;
  border-radius: 100rpx;
  margin-top: 6rpx;
}

.ul-green  { background: #4ADE80; }
.ul-red    { background: #F87171; }
.ul-orange { background: #FB923C; }
.ul-gray   { background: #CBD5E1; }
.ul-dim    { background: #E2E8F0; }

/* ── 选中日详情 ── */
.day-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F1F5;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

/* ── 无计划日期详情 ── */
.day-no-plan {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F1F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 8rpx;
  gap: 10rpx;
}

.no-plan-emoji { font-size: 48rpx; }

.no-plan-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #374151;
}

.no-plan-sub {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.6;
}

.detail-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

.chapter-pill {
  background: #EEF0FF;
  color: #5B5FC7;
  border-radius: 100rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.detail-topic {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
}

.done-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #EDFCF2;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.done-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #16A34A;
}

.btn-action-green {
  width: 100%;
  height: 88rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #22C55E, #16A34A);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-green::after { border: none; }

.btn-action-orange {
  width: 100%;
  height: 88rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #FB923C, #EA580C);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-orange::after { border: none; }

.btn-action-red {
  width: 100%;
  height: 88rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #F87171, #DC2626);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-red::after { border: none; }

.btn-action-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-action-primary::after { border: none; }

/* ── 项目进度入口卡 ── */
.project-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.project-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.project-icon {
  width: 80rpx;
  height: 80rpx;
  background: #EEF0FF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.project-entry-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 4rpx;
}

.project-entry-sub {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.project-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
}

.weakness-icon {
  background: #FFF4EC;
}

.review-icon {
  background: #F0FDF4;
}

/* ── 最近完成 ── */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recent-info {
  flex: 1;
}

.recent-topic {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4rpx;
}

.recent-date {
  display: block;
  font-size: 20rpx;
  color: #9CA3AF;
}

.recent-scores {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.chip {
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.chip-green {
  background: #EDFCF2;
  color: #16A34A;
}

.chip-red {
  background: #FEE2E2;
  color: #DC2626;
}

/* ── 通用主按钮 ── */
.btn-primary {
  width: 100% !important;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  text-align: center;
  box-sizing: border-box;
}
.btn-primary::after { border: none; }

.today-btn { font-size: 28rpx; }

/* ── Loading 遮罩 ── */
.loading-mask {
  position: fixed;
  inset: 0;
  background: rgba(245, 246, 250, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #E5E7EB;
  border-top-color: #5B5FC7;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
