<view class="page">

  <!-- ── 自定义导航栏 ── -->
  <view class="nav-bar-wrap">
    <view style="height:{{statusBarHeight}}px"></view>
    <view class="nav-bar">
      <view class="nav-back" bindtap="onBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <text class="nav-title">题目列表</text>
      <!-- <text class="nav-count">{{problems.length}}题</text> -->
    </view>
  </view>

  <!-- ── 筛选胶囊标签 ── -->
  <view class="filter-bar">
    <view
      class="filter-pill {{filter === 'all' ? 'pill-active' : ''}}"
      data-filter="all"
      bindtap="onFilterChange"
    >全部 {{problems.length}}</view>
    <view
      class="filter-pill {{filter === 'wrong' ? 'pill-active' : ''}}"
      data-filter="wrong"
      bindtap="onFilterChange"
    >做错 {{wrongCount}}</view>
    <view
      class="filter-pill {{filter === 'unknown' ? 'pill-active' : ''}}"
      data-filter="unknown"
      bindtap="onFilterChange"
    >不会 {{unknownCount}}</view>
    <view
      class="filter-pill {{filter === 'correct' ? 'pill-active' : ''}}"
      data-filter="correct"
      bindtap="onFilterChange"
    >答对 {{correctCount}}</view>
  </view>

  <!-- ── 题目列表 ── -->
  <scroll-view class="problem-list" scroll-y enable-flex>

    <view wx:if="{{loading}}" class="list-loading">
      <view class="list-spinner"></view>
    </view>

    <block wx:if="{{!loading}}">
      <view
        wx:for="{{filteredProblems}}"
        wx:key="id"
        class="problem-row"
        data-id="{{item.id}}"
        data-seq="{{item.seq}}"
        bindtap="onProblemTap"
      >
        <!-- 左：圆形状态图标 -->
        <view class="circle circle-{{item.result}}">
          <text class="circle-icon">{{item.result === 'correct' ? '✓' : item.result === 'wrong' ? '×' : '?'}}</text>
        </view>

        <!-- 中：题号 + 知识点 -->
        <view class="row-body">
          <text class="row-title">第 {{item.seq}} 题</text>
          <text wx:if="{{item.knowledgePoint}}" class="row-kp">{{item.knowledgePoint}}</text>
        </view>

        <!-- 右：状态文字 + 复盘状态 -->
        <view class="row-status">
          <text class="status-label status-{{item.result}}">
            {{item.result === 'correct' ? '答对了' : item.result === 'wrong' ? '做错了' : '不会做'}}
          </text>
          <text wx:if="{{item.reviewStatus === 'done'}}" class="status-sub status-reviewed">已复盘</text>
          <text wx:if="{{item.reviewStatus !== 'done'}}" class="status-sub">待复盘</text>
        </view>
      </view>

      <view wx:if="{{filteredProblems.length === 0}}" class="empty-hint">
        <text>该分类下暂无题目</text>
      </view>
    </block>

  </scroll-view>

  <!-- ── 底部开始复盘按钮 ── -->
  <view class="footer-wrap">
    <view class="btn-complete" bindtap="onStartReview">开始复盘</view>
    <view style="height:{{safeAreaBottom}}px"></view>
  </view>

</view>
