.page { display: flex; flex-direction: column; min-height: 100vh; background: #F5F6FA; }

/* Hero */
.project-hero {
  background: linear-gradient(135deg, #4338CA, #5B5FC7);
  padding: 32rpx 32rpx 40rpx;
  color: #fff;
  flex-shrink: 0;
}
.hero-name { display: block; font-size: 28rpx; font-weight: 800; margin-bottom: 8rpx; }
.hero-sub { display: block; font-size: 24rpx; opacity: 0.8; margin-bottom: 24rpx; }
.hero-stats { display: flex; gap: 20rpx; }
.h-stat {
  flex: 1;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 16rpx;
  text-align: center;
}
.h-stat-val { display: block; font-size: 36rpx; font-weight: 800; }
.h-stat-label { display: block; font-size: 20rpx; opacity: 0.7; margin-top: 4rpx; }

.scroll { flex: 1; padding: 20rpx 0; }

/* 里程碑卡 */
.ms-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
  position: relative;
  overflow: hidden;
}
.ms-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  border-radius: 8rpx 0 0 8rpx;
}
.ms-m1::before { background: #5B5FC7; }
.ms-m2::before { background: #F59E0B; }
.ms-m3::before { background: #10B981; }
.ms-pending { opacity: 0.55; }

.ms-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.ms-badge {
  font-size: 20rpx; font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
}
.ms-badge-blue { background: #EEF0FF; color: #5B5FC7; }
.ms-badge-amber { background: #FFFBEB; color: #D97706; }
.ms-badge-green { background: #ECFDF5; color: #059669; }
.ms-title { font-size: 28rpx; font-weight: 700; color: #111827; }
.ms-date { display: block; font-size: 22rpx; color: #9CA3AF; margin-bottom: 16rpx; }

.ms-progress-row {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}
.ms-pct { font-weight: 600; }

.progress-track {
  height: 12rpx;
  background: #EEF0FF;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: #5B5FC7;
  transition: width 0.3s;
}

.ms-footer { display: flex; align-items: center; justify-content: space-between; }
.ms-footer-text { font-size: 22rpx; color: #9CA3AF; flex: 1; }
.retro-btn {
  font-size: 22rpx;
  color: #5B5FC7;
  background: #EEF0FF;
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
}
.card-title { display: block; font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 20rpx; }

/* 热力图 */
.heatmap {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.hm-cell {
  aspect-ratio: 1;
  border-radius: 8rpx;
}
.heatmap-legend {
  display: flex;
  gap: 24rpx;
  align-items: center;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 20rpx; color: #9CA3AF; }
.l-dot { width: 20rpx; height: 20rpx; border-radius: 4rpx; }
