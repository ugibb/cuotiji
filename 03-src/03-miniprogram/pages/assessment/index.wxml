<view class="page">

  <!-- 步骤条 -->
  <view class="header">
    <view class="header-top">
      <text class="nav-title">诊断测试</text>
      <text class="nav-count">{{answered}}/{{total}}</text>
    </view>
    <view class="flow-bar">
      <view class="flow-seg seg-done"></view>
      <view class="flow-seg seg-done"></view>
      <view class="flow-seg seg-now"></view>
      <view class="flow-seg"></view>
      <view class="flow-seg"></view>
    </view>
    <text class="step-label">第 3 步，共 5 步 · 展示前 3 题（共 15 题）</text>
  </view>

  <scroll-view class="scroll" scroll-y>
    <text class="intro">根据你的问卷，AI 为你选了 <text style="font-weight:700;color:#111827">15 道</text>诊断题，涵盖 3 个重点知识域。\n放心作答，做错没关系，这正是诊断用的。</text>

    <!-- 题目列表 -->
    <view wx:for="{{questions}}" wx:key="id" class="card">
      <view class="q-header">
        <view class="topic-chip topic-{{item.topicColor}}">{{item.topic}}</view>
        <text class="q-num">第 {{index + 1}} 题</text>
      </view>
      <view class="q-body">
        <text class="q-text">{{item.question}}</text>
      </view>
      <view class="choices">
        <view
          wx:for="{{item.options}}"
          wx:key="label"
          wx:for-item="opt"
          wx:for-index="oi"
          class="choice {{answers[item.id] === opt.label ? 'choice-sel' : ''}}"
          bindtap="onPick"
          data-qid="{{item.id}}"
          data-label="{{opt.label}}"
        >
          <view class="radio {{answers[item.id] === opt.label ? 'radio-sel' : ''}}">
            <view wx:if="{{answers[item.id] === opt.label}}" class="radio-dot"></view>
          </view>
          <text class="choice-text">{{opt.label}}. {{opt.text}}</text>
        </view>
      </view>
    </view>

    <!-- 剩余提示 -->
    <view class="rest-hint">
      … 剩余 12 道题已在系统中准备好，提交前 3 题后继续 …
    </view>

    <view style="height:200rpx"></view>
  </scroll-view>

  <!-- 底部 -->
  <view class="bottom-bar">
    <button class="btn-primary {{answered >= 3 ? '' : 'btn-disabled'}}" bindtap="onSubmit">提交答案，查看能力报告 →</button>
  </view>

</view>
