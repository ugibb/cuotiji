/* ── 题目详情页（对照高保真原型） ── */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

/* ── 自定义导航栏 ── */
.nav-wrap {
  background: #fff;
  flex-shrink: 0;
  border-bottom: 1rpx solid #eee;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 52rpx;
  font-weight: 300;
  color: #333;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.nav-progress {
  width: 72rpx;
  text-align: right;
  font-size: 28rpx;
  color: #4845a4;
  font-weight: 600;
  flex-shrink: 0;
}

/* ── 可滚动内容区 ── */
.content {
  flex: 1;
  box-sizing: border-box;
  padding: 24rpx 32rpx 24rpx;
}

/* 加载占位 */
.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.page-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(72, 69, 164, 0.15);
  border-top-color: #4845a4;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 题目卡 ── */
.section {
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: #aaa;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* ── 答案区（做错：两列并排） ── */
.answer-row-wrap {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.answer-box {
  flex: 1;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.box-wrong   { background: rgba(229, 80, 80, 0.08); }
.box-correct { background: rgba(77, 188, 108, 0.08); }

.answer-box-label {
  font-size: 22rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.label-wrong   { color: #e55050; }
.label-correct { color: #4dbc6c; }

.answer-box-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 答案区（答对：单列） */
.answer-single {
  margin-bottom: 16rpx;
}

.answer-single .answer-box-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #4dbc6c;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.answer-val-correct {
  font-size: 36rpx;
  font-weight: 700;
  color: #4dbc6c;
}

/* ── 判断 Banner ── */
.verdict {
  border-radius: 12rpx;
  height: 80rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.verdict-wrong   { background: rgba(229, 80, 80, 0.10); }
.verdict-correct { background: rgba(77, 188, 108, 0.10); }

.verdict-icon {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.verdict-wrong .verdict-icon   { color: #e55050; }
.verdict-correct .verdict-icon { color: #4dbc6c; }

.verdict-text {
  font-size: 30rpx;
  font-weight: 700;
}

.verdict-wrong .verdict-text   { color: #e55050; }
.verdict-correct .verdict-text { color: #4dbc6c; }

/* ── 分析卡 ── */
.analysis-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.analysis-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.analysis-item:last-child { border-bottom: none; }

.analysis-icon {
  font-size: 36rpx;
  line-height: 1.2;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.analysis-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.analysis-label {
  font-size: 22rpx;
  color: #aaa;
  font-weight: 600;
}

.analysis-val {
  font-size: 28rpx;
  color: #333;
  line-height: 1.65;
}

/* ── AI 辅导对话区 ── */
.dialogue-section {
  margin-bottom: 0;
}

.dialogue-header {
  font-size: 20rpx;
  font-weight: 700;
  color: #bbb;
  letter-spacing: 3rpx;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.dialogue-empty {
  text-align: center;
  padding: 40rpx 0 32rpx;
  font-size: 26rpx;
  color: #ccc;
}

/* 气泡行 */
.bubble-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.row-ai      { flex-direction: row; }
.row-student { flex-direction: row-reverse; padding-right: 20rpx; }

/* AI 头像 */
.ai-avatar {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #4845a4;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

/* 气泡 */
.bubble {
  max-width: 72%;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
}

.bubble-ai {
  background: #fff;
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
}

.bubble-student {
  background: #4845a4;
  border-radius: 16rpx 4rpx 16rpx 16rpx;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
}

.bubble-ai .bubble-text      { color: #333; }
.bubble-student .bubble-text { color: #fff; }

.bubble-typing .bubble-text {
  color: #aaa;
  font-style: italic;
}

/* 提示文字 */
.dialogue-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin: 8rpx 0 32rpx;
  letter-spacing: 0.5rpx;
}

/* 底部输入栏由 chat-input 组件接管 */

/* ── AI 驱动的进入下一题行动卡 ── */
.next-action-row {
  display: flex;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}

.next-action-text {
  display: inline-block;
  background: #4845a4;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  padding: 20rpx 56rpx;
  border-radius: 48rpx;
}

/* ── 图片气泡 ── */
.chat-image {
  width: 360rpx;
  border-radius: 16rpx;
  display: block;
}

/* ── 复盘完成标识 ── */
.review-complete-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  margin: 24rpx 32rpx 0;
  border-top: 1rpx solid #e8e8e8;
}

.complete-check {
  font-size: 56rpx;
  color: #4caf50;
  margin-bottom: 12rpx;
}

.complete-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.complete-sub {
  font-size: 24rpx;
  color: #999;
}

/* ── 复盘完成禁用栏 ── */
.review-done-bar {
  background: #f5f5f5;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
}

.review-done-text {
  font-size: 26rpx;
  color: #bbb;
}
