/* ── 复盘完成页（对照高保真原型） ── */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

.safe-top {
  background: #f5f7fa;
  flex-shrink: 0;
}

/* ── 主内容区（撑满剩余高度，内容上下居中） ── */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx 40rpx;
}

/* 奖杯 */
.trophy {
  font-size: 112rpx;
  line-height: 1.2;
  margin-bottom: 32rpx;
}

/* 标题 */
.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: 0.5rpx;
  margin-bottom: 32rpx;
}

/* ── 摘要文字 ── */
.summary-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
}

.sum-line {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.sum-plain {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.sum-hl {
  font-size: 28rpx;
  font-weight: 700;
  color: #4845a4;
  line-height: 1.8;
}

/* ── 家长通知卡 ── */
.notify-card {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e8e8ee;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.notify-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  line-height: 1;
}

.notify-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.notify-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #4845a4;
}

.notify-sub {
  font-size: 24rpx;
  color: #aaa;
  line-height: 1.5;
}

/* ── 底部按钮 ── */
.footer {
  flex-shrink: 0;
  padding: 0 48rpx 24rpx;
}

.btn-home {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #4845a4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
  box-sizing: border-box;
}
