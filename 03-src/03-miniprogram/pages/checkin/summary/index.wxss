/* ── 批改完成总结页（对照高保真原型） ── */

.summary-page {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

.safe-top {
  background: #3d3b9c;
  flex-shrink: 0;
}

/* ── 加载占位 ── */
.page-loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(61, 59, 156, 0.15);
  border-top-color: #3d3b9c;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── Hero 渐变区 ── */
.hero {
  background: linear-gradient(170deg, #3d3b9c 0%, #5b57c9 100%);
  padding: 32rpx 48rpx 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── 顶部导航栏 ── */
.nav-bar {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.nav-back-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-arrow {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.hero-emoji {
  font-size: 64rpx;
  line-height: 1.2;
  margin-bottom: 16rpx;
}

/* 大分数 */
.score-row {
  display: flex;
  align-items: baseline;
  gap: 0;
  margin-bottom: 20rpx;
}

.score-correct,
.score-slash,
.score-total {
  font-size: 112rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  letter-spacing: -2rpx;
}

.score-slash {
  font-size: 72rpx;
  font-weight: 300;
  margin: 0 12rpx;
  opacity: 0.7;
}

/* 章节副标题 */
.hero-chapter {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  text-align: center;
  margin-bottom: 32rpx;
  letter-spacing: 0.5rpx;
}

/* AI 评语 */
.hero-comment {
  font-size: 30rpx;
  color: #fff;
  text-align: center;
  line-height: 1.75;
  white-space: pre-line;
  font-weight: 500;
  padding: 0 8rpx;
}

/* ── 白色内容区 ── */
.body-section {
  background: #f5f7fa;
  flex: 1;
  padding: 0 32rpx 320rpx;
}

/* ── 三列统计卡（上移压住 hero 底部） ── */
.stat-card {
  margin-top: -64rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 28rpx rgba(61, 59, 156, 0.10);
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 8rpx;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border-radius: 12rpx;
  transition: background 0.15s;
}

.stat-col-active {
  background: rgba(0, 0, 0, 0.04);
  margin: 0 8rpx 0 8rpx;
}

.stat-col-active-all     { border-bottom: 4rpx solid #4845a4; }
.stat-col-active-correct { border-bottom: 4rpx solid #4dbc6c; }
.stat-col-active-wrong   { border-bottom: 4rpx solid #e55050; }
.stat-col-active-unknown { border-bottom: 4rpx solid #f59e0b; }

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: #eee;
  flex-shrink: 0;
}

.stat-num {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2rpx;
}

.num-total   { color: #4845a4; }
.num-correct { color: #4dbc6c; }
.num-wrong   { color: #e55050; }
.num-unknown { color: #bbb; }

.stat-label {
  font-size: 24rpx;
  color: #aaa;
  font-weight: 500;
}

/* ── 知识点标签区 ── */
.kp-section {
  padding: 0 4rpx;
  margin-bottom: 16rpx;
}

.kp-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 24rpx;
}

.kp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.kp-tag {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
}

.kp-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* 已掌握：绿色 */
.kp-mastered {
  background: #eaf9ef;
  border: 1rpx solid #b7e8c8;
}
.kp-mastered .kp-text { color: #27ae60; }

/* 待突破：红色 */
.kp-struggling {
  background: #fff0f0;
  border: 1rpx solid #ffd0d0;
}
.kp-struggling .kp-text { color: #e54747; }

/* 待分析：橙色 */
.kp-unknown {
  background: #fff8e8;
  border: 1rpx solid #f5d68c;
}
.kp-unknown .kp-text { color: #d98c00; }

/* ── 题目列表区 ── */
.problem-section {
  padding: 0 4rpx;
  margin-bottom: 16rpx;
}

.problem-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 20rpx;
}

.problem-row {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-wrong   { background: rgba(229, 80, 80, 0.12); }
.circle-correct { background: rgba(77, 188, 108, 0.12); }
.circle-unknown { background: rgba(245, 158, 11, 0.12); }

.circle-icon {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.circle-wrong   .circle-icon { color: #e55050; }
.circle-correct .circle-icon { color: #4dbc6c; }
.circle-unknown .circle-icon { color: #f59e0b; }

.row-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.row-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 0.5rpx;
}

.row-kp {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-status {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.status-label {
  font-size: 26rpx;
  font-weight: 600;
}

.status-wrong   { color: #e55050; }
.status-correct { color: #4dbc6c; }
.status-unknown { color: #f59e0b; }

.status-sub {
  font-size: 22rpx;
  color: #ccc;
  font-weight: 400;
}

.status-reviewed {
  color: #52c41a;
}

.empty-hint {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #bbb;
}

/* ── 底部固定按钮区 ── */
.btn-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx 0;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #4845a4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
  box-sizing: border-box;
}

.btn-ghost {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: 2rpx solid #d8d8d8;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #555;
  box-sizing: border-box;
}
