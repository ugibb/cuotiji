/* ── 题目列表页（对照高保真原型） ── */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

/* ── 自定义导航栏 ── */
.nav-bar-wrap {
  background: #fff;
  flex-shrink: 0;
  border-bottom: 1rpx solid #eee;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 52rpx;
  font-weight: 300;
  color: #333;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 0.5rpx;
}

.nav-count {
  width: 64rpx;
  text-align: right;
  font-size: 26rpx;
  color: #aaa;
  font-weight: 400;
  flex-shrink: 0;
}

/* ── 筛选胶囊标签 ── */
.filter-bar {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 24rpx 32rpx 20rpx;
  background: #fff;
  flex-shrink: 0;
  overflow-x: auto;
}

.filter-pill {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  background: #f0f0f4;
}

.filter-pill.pill-active {
  background: #4845a4;
  color: #fff;
  font-weight: 600;
}

/* ── 题目列表（可滚动） ── */
.problem-list {
  flex: 1;
  overflow: hidden;
  padding: 20rpx 32rpx 0;
}

/* 加载占位 */
.list-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.list-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(72, 69, 164, 0.15);
  border-top-color: #4845a4;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 题目行 ── */
.problem-row {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 圆形状态图标 */
.circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-wrong   { background: rgba(229, 80, 80, 0.12); }
.circle-correct { background: rgba(77, 188, 108, 0.12); }
.circle-unknown { background: rgba(245, 158, 11, 0.12); }

.circle-icon {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.circle-wrong   .circle-icon { color: #e55050; }
.circle-correct .circle-icon { color: #4dbc6c; }
.circle-unknown .circle-icon { color: #f59e0b; }

/* 中间：题号 + 知识点 */
.row-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.row-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 0.5rpx;
}

.row-kp {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧：状态 + 待复盘 */
.row-status {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.status-label {
  font-size: 26rpx;
  font-weight: 600;
}

.status-wrong   { color: #e55050; }
.status-correct { color: #4dbc6c; }
.status-unknown { color: #f59e0b; }

.status-sub {
  font-size: 22rpx;
  color: #ccc;
  font-weight: 400;
}

/* 空状态 */
.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #bbb;
}

/* ── 底部按钮区 ── */
.footer-wrap {
  flex-shrink: 0;
  padding: 20rpx 32rpx 0;
  background: #f5f7fa;
}

.btn-complete {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #4845a4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
  box-sizing: border-box;
}
