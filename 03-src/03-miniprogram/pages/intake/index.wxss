.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F6FA;
}

/* 步骤条 */
.flow-bar {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 32rpx 0;
  background: #fff;
  flex-shrink: 0;
}
.flow-seg {
  flex: 1;
  height: 8rpx;
  border-radius: 4rpx;
  background: #E5E7EB;
}
.seg-done { background: #5B5FC7; }
.seg-now { background: #A5B4FC; }

.step-label {
  display: block;
  padding: 8rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: #9CA3AF;
  background: #fff;
}

.scroll { flex: 1; padding: 16rpx 0 0; }

.intro {
  display: block;
  padding: 0 32rpx 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 24rpx;
}
.q-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
}
.choices {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.choice {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #F5F6FA;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}
.choice-sel {
  background: #EEF0FF;
  border-color: #5B5FC7;
}
.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.radio-sel {
  background: #5B5FC7;
  border-color: #5B5FC7;
}
.radio-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}
.choice-text {
  font-size: 26rpx;
  color: #374151;
}
.choice-sel .choice-text {
  color: #4338CA;
  font-weight: 600;
}

.ai-hint {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  background: #EEF0FF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}
.ai-hint-icon { font-size: 32rpx; flex-shrink: 0; margin-top: 2rpx; }
.ai-hint-text { font-size: 24rpx; color: #4338CA; line-height: 1.6; }

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F1F5;
}
.btn-primary {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5B5FC7, #4338CA);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }
.btn-disabled {
  background: #E5E7EB !important;
  color: #9CA3AF !important;
}
